#!/bin/sh
# Flags do BEAM para produção em edge computing
# +P 1_000_000 — max processes (suporta 10k+ heartbeats concorrentes)
# +Q 65_536    — max open ports
# +S auto      — schedulers = núcleos disponíveis
export ERL_FLAGS="+P 1000000 +Q 65536"

# Sem clustering (single-node edge deployment)
export RELEASE_DISTRIBUTION=none
